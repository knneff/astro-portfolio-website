---
import ButtonLink from "../components/ButtonLink.astro";
import Section from "../components/Section.astro";
---

<Section>
    <header id="header">
        <div class="content">
            <h1>
                <!-- header goes here (hint: use <span class="accent"> for accented text) -->
                <span>Hi. I am Ken.</span>
                <span><span class="accent">Data Scientist</span> Aspirant!</span
                >
            </h1>
            <p class="description">
                <!-- description goes here -->
                Computer Science undergraduate specializing in data analysis, SQL,
                and data visualization. Experienced inexploratory data analysis (EDA),
                dashboarding with Power BI & Tableau, and data-driven projects using
                Python and SQL.
            </p>
            <div class="button-container">
                <!-- view projects link goes here -->
                <ButtonLink
                    href="/projects"
                    text="View Projects"
                    variant="secondary"
                />

                <!-- download resume link goes here (hint: use the download property) -->
                <ButtonLink
                    href="/resume.pdf"
                    text="Download Resume"
                    isDownload
                />
            </div>
        </div>
        <!-- image goes here -->
        <img src="/images/me.png" alt="Profile Image" class="profile-image" />
    </header>
</Section>

<style>
    #header {
        display: grid;
        grid-template-columns: 540px 1fr;
        justify-items: center;
        gap: 80px;
        align-items: center;

        @media (max-width: 1000px) {
            & {
                grid-template-columns: 1fr;
                grid-template-rows: auto;
                gap: 40px;

                img {
                    grid-row: 1;
                }
            }
        }
    }

    h1 {
        font-size: 44px;
        margin-bottom: 10px;
        display: flex;
        flex-direction: column;

        .accent {
            color: var(--primary);
        }
    }

    .button-container {
        display: flex;
        gap: 10px;
    }

    .description {
        line-height: 28px;
        color: var(--dark);
        margin-bottom: 30px;
    }

    .profile-image {
        width: 250px;
        height: auto;
        border-radius: 50%;
        object-fit: cover;
    }

    @media (max-width: 600px) {
        .button-container {
            flex-direction: column;
            gap: 10px;
        }
    }
</style>
